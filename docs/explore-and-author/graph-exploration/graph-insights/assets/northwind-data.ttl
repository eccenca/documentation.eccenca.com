@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix void: <http://rdfs.org/ns/void#> .

nw: a void:Dataset ;
    rdfs:label "Northwind Database" ;
.

nw:Agent a rdfs:Class,
        owl:Class ;
    rdfs:label "Agent" .

nw:Customer a rdfs:Class,
        owl:Class ;
    rdfs:label "Customer" ;
    rdfs:subClassOf nw:Agent .

nw:Employee a rdfs:Class,
        owl:Class ;
    rdfs:label "Employee" ;
    rdfs:subClassOf nw:Agent .

nw:Order a rdfs:Class,
        owl:Class ;
    rdfs:label "Order" .

nw:Product a rdfs:Class,
        owl:Class ;
    rdfs:label "Product" .

nw:Region a rdfs:Class,
        owl:Class ;
    rdfs:label "Region" .

nw:Shipper a rdfs:Class,
        owl:Class ;
    rdfs:label "Shipper" ;
    rdfs:subClassOf nw:Agent .

nw:Supplier a rdfs:Class,
        owl:Class ;
    rdfs:label "Supplier" ;
    rdfs:subClassOf nw:Agent .

nw:Territory a rdfs:Class,
        owl:Class ;
    rdfs:label "Territory" .

nw:address a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "address" .

nw:belongsToOrder a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "belongsToOrder" .

nw:birthDate a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "birthDate" .

nw:categoryID a rdf:Property ;
    rdfs:label "categoryID" .

nw:city a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "city" .

nw:companyName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "companyName" .

nw:contactName a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "contactName" .

nw:contactTitle a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "contactTitle" .

nw:country a rdf:Property,
        owl:DatatypeProperty ;
    rdfs:label "country" .

