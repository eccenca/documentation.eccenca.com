    rdfs:label "customer-FISSA" ;
    nw:address "C/ Moralzarzal, 86" ;
    nw:city "Madrid" ;
    nw:companyName "FISSA Fabrica Inter. Salchichas S.A." ;
    nw:contactName "Diego Roel" ;
